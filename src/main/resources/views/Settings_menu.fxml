<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: beige;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ttmc2026.controllers.SettingsController">
   <children>
      <BorderPane fx:id="border" maxHeight="400.0" maxWidth="600.0" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: beige;">
         <top>
            <Label fx:id="settingsLabel" text="Settings" BorderPane.alignment="CENTER">
               <font>
                  <Font size="28.0" />
               </font>
               <BorderPane.margin>
                  <Insets top="15.0" />
               </BorderPane.margin>
            </Label>
         </top>
         <center>
            <VBox alignment="CENTER" BorderPane.alignment="CENTER">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <VBox prefHeight="328.0" prefWidth="97.0">
                           <children>
                              <CheckBox fx:id="fullscreenCheckBox" mnemonicParsing="false" onAction="#isFullscreen" text="Fullscreen">
                                 <VBox.margin>
                                    <Insets left="10.0" top="10.0" />
                                 </VBox.margin>
                              </CheckBox>
                              <Label fx:id="volumeLabel" text="Volume :">
                                 <VBox.margin>
                                    <Insets left="10.0" top="100.0" />
                                 </VBox.margin>
                                 <font>
                                    <Font size="15.0" />
                                 </font>
                              </Label>
                              <CheckBox fx:id="muteCheckBox" mnemonicParsing="false" onAction="#isMute" text="Mute">
                                 <VBox.margin>
                                    <Insets left="10.0" top="10.0" />
                                 </VBox.margin>
                              </CheckBox>
                           </children>
                        </VBox>
                        <Slider fx:id="volumeSlider">
                           <HBox.margin>
                              <Insets left="-15.0" top="130.0" />
                           </HBox.margin>
                        </Slider>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </center>
         <bottom>
            <HBox alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="previousButton" mnemonicParsing="false" onAction="#onPreviousButtonClick" text="Previous" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="saveButton" alignment="BOTTOM_RIGHT" contentDisplay="RIGHT" mnemonicParsing="false" onAction="#onSaveButtonClick" text="Save" />
               </children>
               <padding>
                  <Insets left="10.0" right="10.0" bottom="15.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</StackPane>